        "required": false
      },
      {
        "key": "party_id_number",
        "label": "居民身份证号码",
        "type": "id_card",
        "required": false
      },
      {
        "key": "birth_date",
        "label": "出生日期",
        "type": "date",
        "required": false
      },
      {
        "key": "native_place",
        "label": "籍贯",
        "type": "text",
        "required": false
      },
      {
        "key": "household_register",
        "label": "户籍地",
        "type": "text",
        "required": false
      },
      {
        "key": "party_address",
        "label": "现住址",
        "type": "text",
        "required": false
      },
      {
        "key": "work_unit",
        "label": "工作单位",
        "type": "text",
        "required": false
      },
      {
        "key": "criminal_record",
        "label": "违法犯罪经历",
        "type": "text",
        "required": false
      },
      {
        "key": "case_occurrence_date",
        "label": "案发日期",
        "type": "date",
        "required": true
      },
      {
        "key": "case_occurrence_place",
        "label": "案发地点",
        "type": "text",
        "required": true
      },
      {
        "key": "illegal_fact",
        "label": "违法事实（完整叙述，含证据）",
        "type": "text",
        "required": true
      },
      {
        "key": "penalty_basis",
        "label": "处罚依据",
        "type": "text",
        "required": true
      },
      {
        "key": "penalty_content",
        "label": "处罚内容",
        "type": "text",
        "required": true
      },
      {
        "key": "fine_amount",
        "label": "罚款金额（元）",
        "type": "number",
        "required": false
      },
      {
        "key": "execution_detail",
        "label": "执行方式和期限",
        "type": "text",
        "required": false
      },
      {
        "key": "doc_number",
        "label": "文书编号",
        "type": "text",
        "required": false
      },
      {
        "key": "penalty_decision_date",
        "label": "处罚决定日期",
        "type": "date",
        "required": true
      },
      {
        "key": "reconsideration_org",
        "label": "行政复议机关",
        "type": "text",
        "required": false
      },
      {
        "key": "lawsuit_court",
        "label": "行政诉讼法院",
        "type": "text",
        "required": false
      },
      {
        "key": "case_number",
        "label": "案件编号",
        "type": "text",
        "required": false
      },
      {
        "key": "personnel_number",
        "label": "人员编号",
        "type": "text",
        "required": false
      },
      {
        "key": "department",
        "label": "办案单位",
        "type": "text",
        "required": true
      },
      {
        "key": "author_name",
        "label": "办案民警",
        "type": "text",
        "required": true
      }
    ],
    "template_text": "{{department}}\n行政处罚决定书\n{{doc_number}}\n违法行为人{{party_name}}，{{party_gender}}，{{party_age}}岁，居民身份证号码{{party_id_number}}，{{birth_date}}出生，籍贯：{{native_place}}，户籍：{{household_register}}，现住：{{party_address}}，工作单位：{{work_unit}}，违法犯罪经历：{{criminal_record}}。\n\n{{illegal_fact}}，以上事实有检查笔录、违法行为人的陈述和申辩，其他等证据证实。\n\n根据{{penalty_basis}}之规定，现决定对违法行为人{{party_name}}处以{{penalty_content}}。\n\n执行方式和期限{{execution_detail}}\n\n逾期不交纳罚款的，每日按罚款数额的百分之三加处罚款，罚款的数额不超过罚款本数。\n\n一式四份，被处罚人和执行单位各一份，被侵害人一份，一份附卷。登陆www.gazxfz.gov.cn查询该行政处罚公开和网上申请行政复议。\n\n如不服本决定，可以在收到本决定书之日起六十日内向{{reconsideration_org}}申请行政复议或者在六个月内依法向{{lawsuit_court}}提起行政诉讼。\n\n附：  清单共  份\n\n{{department}}\n{{stamp_date}}\n\n行政处罚决定书已向我宣告并送达。\n被处罚人:                        被侵害人：\n          年    月    日                  年    月    日\n接收人员：\n接收单位（印）\n          年    月    日\n\n案件编号：{{case_number}}\n人员编号：{{personnel_number}}",
    "fixed_clauses": [
      "如不服本决定，可以在收到本决定书之日起六十日内申请行政复议或者在六个月内依法提起行政诉讼。",
      "逾期不交纳罚款的，每日按罚款数额的百分之三加处罚款，罚款的数额不超过罚款本数。",
      "一式四份，被处罚人和执行单位各一份，被侵害人一份，一份附卷。"
    ],
    "format_rules": {
      "paper_size": "A4",
      "font": "仿宋_GB2312",
      "title_font_size": "小二",
      "body_font_size": "三号",
      "body_indent": "首行缩进2字符"
    }
  },
  {
    "id": "tpl-006",
    "doc_type": "检查笔录",
    "name": "检查笔录",
    "description": "公安机关对违法嫌疑人身体、物品、场所进行检查的法律文书（依据治安管理处罚法第八十七条）",
    "schema_fields": [
      {
        "key": "police_station",
        "label": "公安机关名称",
        "type": "text",
        "required": true
      },
      {
