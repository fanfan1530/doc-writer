      },
      {
        "key": "inspection_time_end",
        "label": "检查结束时间",
        "type": "datetime",
        "required": true
      },
      {
        "key": "inspection_place",
        "label": "检查地点（默认为公安机关名称+检查室）",
        "type": "text",
        "required": false
      },
      {
        "key": "inspection_target",
        "label": "被检查人（姓名）",
        "type": "text",
        "required": true
      },
      {
        "key": "violation_type",
        "label": "违法性质",
        "type": "text",
        "required": true
      },
      {
        "key": "inspector_name",
        "label": "检查人姓名",
        "type": "text",
        "required": true
      },
      {
        "key": "inspector_unit",
        "label": "检查人工作单位",
        "type": "text",
        "required": true
      },
      {
        "key": "witness_info",
        "label": "见证人基本情况（姓名、性别、身份证件种类及号码）",
        "type": "text",
        "required": true
      },
      {
        "key": "items_found",
        "label": "有无发现涉案物品",
        "type": "text",
        "required": true
      },
      {
        "key": "injury_found",
        "label": "有无发现损伤",
        "type": "text",
        "required": true
      }
    ],
    "template_text": "{{police_station}}\n检 查 笔  录\n\n检查时间：{{inspection_time_start}}至{{inspection_time_end}}\n检查地点：{{inspection_place}}\n检查对象：{{inspection_target_display}}\n检查人姓名和工作单位：{{inspector_unit}}\n见证人基本情况 （姓名、性别、身份证件种类及号码）\n\n事由和目的：{{inspection_reason}}\n过程和结果：{{inspection_date}}，我所民警将涉嫌{{violation_type}}的违法嫌疑人{{inspection_target}}抓获，民警对违法嫌疑人{{inspection_target}}出示人民警察证，根据《中华人民共和国治安管理处罚法》第八十七条第一款之规定依法对违法嫌疑人{{inspection_target}}的身体进行检查。经检查，在违法嫌疑人{{inspection_target}}身上{{items_found}}，在{{inspection_target}}身上{{injury_found}}，被检查人{{inspection_target}}配合检查工作。\n检查人：　　　　　　　　　　　　年　月　日\n见证人：　　　　　　　　　　　　年　月　日\n当事人：　　　　　　　　　　　　年　月　日",
    "fixed_clauses": [],
    "format_rules": {
      "paper_size": "A4",
      "font": "仿宋_GB2312",
      "law_ref": "《中华人民共和国治安管理处罚法》第八十七条",
      "signature_required": true
    }
  },
