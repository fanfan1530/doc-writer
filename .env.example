# ============================================================
# 智能文书编写系统 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# 默认 LLM 配置（当 models.json 中未配置模型时使用）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_LARGE=deepseek-v4-pro
LLM_MODEL_SMALL=deepseek-v4-flash

# 应用配置
APP_NAME=智能文书编写系统
APP_VERSION=1.0.0
DEBUG=false

# 知识库目录
KNOWLEDGE_DIR=./app/knowledge

# LLM 输入长度上限
LLM_MAX_INPUT_CHARS=16000

# 速率限制
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# 允许的前端来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# 数据库 (SQLite 本地开发, PostgreSQL 生产)
# DATABASE_URL=sqlite+aiosqlite:///app/knowledge/data.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/docwriter

# Redis (可选，不设置则使用内存回退)
# REDIS_URL=redis://localhost:6379/0

# JWT 认证
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_DAYS=7
